    {
      "description": "Find a bounded set of exact workflow capabilities for a goal.",
      "effect": "local_read",
      "id": "capability_search",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "properties": {
          "kinds": {
            "items": {
              "type": "string"
            },
            "type": [
              "array",
              "null"
            ]
          },
          "query": {
            "type": "string"
          }
        },
        "required": [
          "kinds",
          "query"
        ],
        "title": "CapabilitySearchInput",
        "type": "object"
      },
      "needs_approval": false,
      "output_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "additionalProperties": false,
        "definitions": {
          "CapabilityPresentationDto": {
            "additionalProperties": false,
            "description": "Non-authoritative display metadata for one exact capability reference.",
            "properties": {
              "category": {
                "description": "Presentation grouping.",
                "type": "string"
              },
              "description": {
                "description": "User-facing description.",
                "type": "string"
              },
              "label": {
                "description": "Short label shown in palettes and node headers.",
                "type": "string"
              },
              "search_terms": {
                "description": "Search terms used by discovery and UI filtering.",
                "items": {
                  "type": "string"
                },
                "type": "array"
              }
            },
            "required": [
              "category",
              "description",
              "label",
              "search_terms"
            ],
            "type": "object"
          },
          "CapabilityRefDto": {
            "additionalProperties": false,
            "description": "Exact identity of one versioned workflow capability.",
            "properties": {
              "id": {
                "description": "Stable capability identifier.",
                "type": "string"
              },
              "version": {
                "description": "Exact semantic contract version.",
                "type": "string"
              }
            },
            "required": [
              "id",
              "version"
            ],
            "type": "object"
          },
          "CapabilityStatusDto": {
            "additionalProperties": false,
            "properties": {
              "availability": {
                "enum": [
                  "available",
                  "unavailable",
                  "degraded"
                ],
                "type": "string"
              },
              "provider_health": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "reason": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "status_revision": {
                "minimum": 0.0,
                "type": "integer"
              }
            },
            "required": [
              "availability",
              "provider_health",
              "reason",
              "status_revision"
            ],
            "type": "object"
          },
          "CapabilitySummaryDto": {
            "additionalProperties": false,
            "description": "A compact palette result containing presentation and live status only.",
            "properties": {
              "presentation": {
                "allOf": [
                  {
                    "$ref": "#/definitions/CapabilityPresentationDto"
                  }
                ],
                "description": "Non-authoritative display metadata."
              },
              "reference": {
                "allOf": [
                  {
                    "$ref": "#/definitions/CapabilityRefDto"
                  }
                ],
                "description": "Exact capability identity that may be loaded into the editor."
              },
              "status": {
                "allOf": [
                  {
                    "$ref": "#/definitions/CapabilityStatusDto"
                  }
                ],
                "description": "Current availability metadata."
              }
            },
            "required": [
              "presentation",
              "reference",
              "status"
            ],
            "type": "object"
          }
        },
        "description": "Output for the bounded capability search operation.",
        "properties": {
          "capabilities": {
            "description": "At most [`MAX_SEARCH_RESULTS`] stable results.",
            "items": {
              "$ref": "#/definitions/CapabilitySummaryDto"
            },
            "type": "array"
          }
        },
        "required": [
          "capabilities"
        ],
        "title": "CapabilitySearchOutput",
        "type": "object"
      },
      "strict_json_schema": true,
      "version": 1
    },

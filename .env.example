# oh-my-dream Assistant Configuration
# Copy this to .env and update with your values for local development

# Enable/disable the assistant
OMD_ASSISTANT_ENABLED=true

# OpenAI-compatible API endpoint
OMD_ASSISTANT_BASE_URL=https://api.openai.com/v1

# LLM model to use
OMD_ASSISTANT_MODEL=gpt-5.4

# API key for the LLM provider (e.g., OpenAI, custom provider)
# IMPORTANT: Never commit the actual key to version control
OMD_ASSISTANT_API_KEY=sk-your-key-here

# Sampling temperature (0-2)
OMD_ASSISTANT_TEMPERATURE=0.3

# Maximum tool/capability call iterations per run
OMD_ASSISTANT_MAX_TOOL_ITERS=20

# Extra system prompt to append to the base prompt
# OMD_ASSISTANT_SYSTEM_PROMPT_EXTRA="Your custom instructions here"

# Allow skills that execute custom code in the sidecar
# WARNING: Only enable for skills you trust
OMD_ASSISTANT_DEVELOPER_MODE=false

# Comma-separated list of enabled skill names
# Example: portrait-helper, cinematic-shots
# OMD_ASSISTANT_ENABLED_SKILLS=portrait-helper,cinematic-shots

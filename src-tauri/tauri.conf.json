{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "oh-my-dream",
  "version": "0.1.0",
  "identifier": "com.ohmydream.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5273",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build"
  },
  "app": {
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/assets/**", "$APPLOCALDATA/assets/**"]
      }
    },
    "windows": [
      {
        "title": "oh-my-dream",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600
      }
    ]
  },
  "bundle": {
    "active": true,
    "externalBin": ["binaries/oh-my-dream-assistant"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

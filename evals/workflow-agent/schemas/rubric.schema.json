{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oh-my-dream.local/evals/workflow-agent/rubric.schema.json",
  "title": "Workflow Agent Evaluation Rubric",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rubric_id",
    "dimensions",
    "hard_gates",
    "aggregation"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "rubric_id": {
      "type": "string"
    },
    "dimensions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "weight",
          "scoring"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "weight": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "scoring": {
            "type": "object",
            "required": [
              "0",
              "1",
              "2",
              "3",
              "4"
            ],
            "additionalProperties": {
              "type": "string"
            }
          }
        }
      }
    },
    "hard_gates": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "aggregation": {
      "type": "object",
      "required": [
        "method",
        "range",
        "partial_run_policy"
      ],
      "properties": {
        "method": {
          "const": "weighted_mean_after_gates"
        },
        "range": {
          "const": "0-4"
        },
        "partial_run_policy": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}

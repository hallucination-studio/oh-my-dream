# Rust / Cargo
/target/
**/target/
# Cargo.lock is committed: workspace ships as an app, so the build is locked.
**/*.rs.bk
*.pdb

# Parallel dev worktrees (Codex tracks); nested here so they sit inside the
# writable project root, but never tracked by the main checkout.
/.worktrees/

# Tauri
/src-tauri/target/
/src-tauri/gen/
/src-tauri/binaries/
/.build/

# Frontend (ui/)
node_modules/
dist/
*.tsbuildinfo
.vite/
*.local

# Python assistant
__pycache__/
*.py[cod]

# Asset library local data (runtime artifacts, not tracked)
/data/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Secrets and local config (cloud vendor API keys never enter the repo)
.env
.env.*
!.env.example
config.local.*

# Editor / OS
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
.DS_Store
.agents
/tasks
